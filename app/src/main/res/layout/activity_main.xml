<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Post-Quantum Cryptography Benchmark"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Device Information"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/device_info_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Algorithm Selection"
            android:textStyle="bold"
            android:textSize="16sp" />

        <RadioGroup
            android:id="@+id/algorithm_type_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <RadioButton
                android:id="@+id/all_radio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All"
                android:checked="true"
                android:layout_marginEnd="16dp" />

            <RadioButton
                android:id="@+id/kem_radio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KEM/Encryption"
                android:layout_marginEnd="16dp" />

            <RadioButton
                android:id="@+id/signature_radio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Signatures" />
        </RadioGroup>

        <CheckBox
            android:id="@+id/quantum_resistant_only_checkbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show only quantum-resistant algorithms"
            android:layout_marginTop="8dp" />

        <Spinner
            android:id="@+id/algorithm_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Operations to Benchmark"
            android:textStyle="bold"
            android:textSize="16sp" />

        <CheckBox
            android:id="@+id/keygen_checkbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Key Generation"
            android:checked="true"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:id="@+id/encryption_options_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="KEM/Encryption Operations"
                android:textStyle="italic"
                android:layout_marginTop="8dp" />

            <CheckBox
                android:id="@+id/encapsulate_checkbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Encapsulate/Encrypt"
                android:checked="true" />

            <CheckBox
                android:id="@+id/decapsulate_checkbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Decapsulate/Decrypt"
                android:checked="true" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/signature_options_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Signature Operations"
                android:textStyle="italic"
                android:layout_marginTop="8dp" />

            <CheckBox
                android:id="@+id/sign_checkbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sign"
                android:checked="true" />

            <CheckBox
                android:id="@+id/verify_checkbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Verify"
                android:checked="true" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <CheckBox
            android:id="@+id/share_benchmark_checkbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Share results after benchmark" />

        <Button
            android:id="@+id/start_benchmark_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start Benchmark"
            android:layout_marginTop="16dp" />

        <ProgressBar
            android:id="@+id/benchmark_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:visibility="gone"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ready to benchmark"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Results"
            android:textStyle="bold"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/results_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textIsSelectable="true" />

    </LinearLayout>
</ScrollView>